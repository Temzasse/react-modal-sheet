{
  "name": "example",
  "version": "1.0.0",
  "license": "MIT",
  "homepage": "https://temzasse.github.io/react-modal-sheet",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "rm -rf dist && vite build --base /react-modal-sheet/",
    "preview": "vite preview --base /react-modal-sheet/",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "format:check": "biome format ./src",
    "format:write": "biome format --write ./src",
    "lint:check": "biome lint --error-on-warnings ./src",
    "lint:write": "biome lint --error-on-warnings  --write ./src",
    "generate:pwa": "pwa-assets-generator --preset minimal public/favicon.svg"
  },
  "dependencies": {
    "motion": "12.35.0",
    "react": "19.2.4",
    "react-aria": "3.47.0",
    "react-dom": "19.2.4",
    "react-icons": "5.6.0",
    "react-modal-sheet": "file:.yalc/react-modal-sheet",
    "react-router": "7.13.1",
    "react-stately": "3.45.0",
    "styled-components": "6.3.11"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vite-pwa/assets-generator": "1.0.2",
    "@vitejs/plugin-react": "5.1.4",
    "gh-pages": "6.3.0",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-pwa": "1.0.3",
    "vite-plugin-restart": "2.0.0"
  }
}
